# ===========================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE
# ===========================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA comite o arquivo .env com credenciais reais!

# Supabase Configuration
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: API Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# Optional: backend API base URL for migration
VITE_BACKEND_API_URL=
VITE_DISABLE_LEGACY_SUPABASE_ADMIN_FLOW=false
VITE_USE_BACKEND_ADMIN_USERS=false
VITE_USE_BACKEND_ACTIONS=false
VITE_USE_BACKEND_REQUESTS=false
VITE_USE_BACKEND_ANNOUNCEMENTS=false
VITE_USE_BACKEND_COMMENTS=false
VITE_USE_BACKEND_AUTH_PROFILE=false
VITE_USE_BACKEND_TAGS=false
VITE_USE_BACKEND_TEAMS=false
VITE_USE_BACKEND_OBJECTIVES_ACTIVITIES=false
VITE_USE_BACKEND_AUTH_SESSION=false

# Optional: frontend observability beacon endpoint
VITE_OBSERVABILITY_BEACON_URL=
